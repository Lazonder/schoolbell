#Python
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Logs & runtime
events.jsonl
events.jsonl.*
*.log

# Temp files
*.tmp
*.bak
*.swp

# Sound files (local)
static/geluiden/*.mp3
static/geluiden/*.wav

# Config (echte data) — zie config.example.json voor een template
config.json
roosters.json
dagplanning.json
standaardweek.json
weken_uit.json
vakanties.json
vakanties_fetch_state.json
daemon_heartbeat.json
users.json

# Lock files for the JSON state above (created by fcntl.flock on
# the sidecar files in webinterface.locked_json / settings_store.locked).
*.lock

# Compiled translation catalogs. The .po files in translations/ are
# the source; .mo is the binary form generated by `pybabel compile`.
# Keeping only .po in git avoids merge frictions caused by tiny
# byte-level differences between Babel versions on different
# machines. install.sh compiles them at install time; contributors
# run `pybabel compile -d translations` once after cloning.
translations/**/*.mo

# Secrets
.env
*.env

# SSL certificates and private keys
certs/
*.pem
*.key

# OS
.DS_Store

