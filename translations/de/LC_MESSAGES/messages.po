#: templates/agenda.html:10
#, python-format
msgid ""
"Importeer schoolvakanties uit\n"
"    <code class=\"sb-code-mono\">data/vakanties.json</code>\n"
"    voor regio <strong>%(vakantieregio)s</strong>\n"
"    (instelbaar via <a href=\"%(settings_url)s\">Voorkeuren</a>).\n"
"    De getroffen weken worden automatisch op <em>Bel uit</em> gezet.\n"
"    Bestaande markeringen blijven staan — de import voegt alleen toe."
